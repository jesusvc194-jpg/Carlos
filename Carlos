local function loadItems(category)
    scroll:ClearAllChildren()
    grid.Parent = scroll

    local list = {}
    if category == "ENGRAJE" then
        list = {
            {emoji="🔨", name="Martillo de Ban", desc="Elimina a los jugadores...", price="1499"},
            {emoji="🖐️", name="Golpe de Agujero Negro", desc="Tira, sujeta y empuja...", price="199"},
            {emoji="🔫", name="Pistola Láser", desc="Lanza láseres...", price="749"},
            {emoji="🌈", name="Alfombra Voladora", desc="¡Te permite volar!", price="375"}
        }
    elseif category == "PASES" then
        list = {
            {emoji="💰", name="2x Dinero", desc="Gana el doble permanentemente", price="169"},
            {emoji="⭐", name="VIP", desc="Muchos beneficios", price="279"},
            {emoji="👑", name="Admin Panel", desc="Comandos de administrador", price="5599"}
        }
    elseif category == "DINERO" then
        list = {
            {emoji="💵", name="$1.300.000", desc="Paquete pequeño", price="369"},
            {emoji="💰", name="$6.500.000", desc="Paquete grande", price="699"},
            {emoji="🤑", name="$13.000.000", desc="Mega paquete", price="1399"}
        }
    end

    for _, item in ipairs(list) do
        local card = Instance.new("Frame")
        card.BackgroundColor3 = Color3.fromRGB(28,28,40)
        card.Parent = scroll

        local icon = Instance.new("TextLabel")
        icon.Size = UDim2.new(0.25,0,0.35,0)
        icon.Position = UDim2.new(0.05,0,0.08,0)
        icon.BackgroundTransparency = 1
        icon.Text = item.emoji
        icon.TextScaled = true
        icon.Parent = card

        local name = Instance.new("TextLabel")
        name.Size = UDim2.new(0.7,0,0.22,0)
        name.Position = UDim2.new(0.32,0,0.08,0)
        name.Text = item.name
        name.TextColor3 = Color3.new(1,1,1)
        name.TextScaled = true
        name.TextXAlignment = Enum.TextXAlignment.Left
        name.BackgroundTransparency = 1
        name.Parent = card

        local desc = Instance.new("TextLabel")
        desc.Size = UDim2.new(0.7,0,0.3,0)
        desc.Position = UDim2.new(0.32,0,0.32,0)
        desc.Text = item.desc
        desc.TextColor3 = Color3.fromRGB(170,170,170)
        desc.TextScaled = true
        desc.TextXAlignment = Enum.TextXAlignment.Left
        desc.BackgroundTransparency = 1
        desc.Parent = card

        local buy = Instance.new("TextButton")
        buy.Size = UDim2.new(0.6,0,0.25,0)
        buy.Position = UDim2.new(0.2,0,0.7,0)
        buy.BackgroundColor3 = Color3.fromRGB(0,170,0)
        buy.Text = "🪙 "..item.price
        buy.TextColor3 = Color3.new(1,1,1)
        buy.TextScaled = true
        buy.Parent = card

        buy.MouseButton1Click:Connect(function()
            game.StarterGui:SetCore("SendNotification",{Title="✅ Comprado", Text=item.name, Duration=4})
        end)
    end
end

