local function createTab(text, x)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.333,0,1,0)
    btn.Position = UDim2.new(x,0,0,0)
    btn.BackgroundColor3 = Color3.fromRGB(40,40,55)
    btn.Text = text
    btn.TextColor3 = Color3.new(1,1,1)
    btn.TextScaled = true
    btn.Parent = tabFrame
    return btn
end

